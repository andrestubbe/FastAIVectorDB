<?xml version="1.0" encoding="UTF-8"?>\r\n<project xmlns="http://maven.apache.org/POM/4.0.0"\r\n         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"\r\n         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0\r\n         http://maven.apache.org/xsd/maven-4.0.0.xsd">\r\n    <modelVersion>4.0.0</modelVersion>\r\n\r\n    <groupId>com.github.andrestubbe</groupId>\r\n    <artifactId>FastAIVectorDB</artifactId>\r\n    <version>0.1.0</version>\r\n    <packaging>jar</packaging>\r\n\r\n    <name>FastAIVectorDB</name>\r\n    <description>Ultrafast in-memory vector store with JNI native backend for the FastJava AI ecosystem</description>\r\n    <url>https://github.com/andrestubbe/FastAIVectorDB</url>\r\n\r\n    <properties>\r\n        <maven.compiler.source>17</maven.compiler.source>\r\n        <maven.compiler.target>17</maven.compiler.target>\r\n        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>\r\n    </properties>\r\n\r\n    <licenses>\r\n        <license>\r\n            <name>MIT License</name>\r\n            <url>https://opensource.org/licenses/MIT</url>\r\n            <distribution>repo</distribution>\r\n        </license>\r\n    </licenses>\r\n\r\n    <developers>\r\n        <developer>\r\n            <name>FastJava Team</name>\r\n            <organization>FastJava</organization>\r\n            <organizationUrl>https://github.com/andrestubbe</organizationUrl>\r\n        </developer>\r\n    </developers>\r\n\r\n    <scm>\r\n        <connection>scm:git:git://github.com/andrestubbe/FastAIVectorDB.git</connection>\r\n        <developerConnection>scm:git:ssh://github.com:andrestubbe/FastAIVectorDB.git</developerConnection>\r\n        <url>https://github.com/andrestubbe/FastAIVectorDB/tree/main</url>\r\n    </scm>\r\n\r\n    <repositories>\r\n        <repository>\r\n            <id>jitpack.io</id>\r\n            <url>https://jitpack.io</url>\r\n        </repository>\r\n    </repositories>\r\n\r\n    <dependencies>\r\n        <dependency>\r\n            <groupId>org.junit.jupiter</groupId>\r\n            <artifactId>junit-jupiter</artifactId>\r\n            <version>5.10.0</version>\r\n            <scope>test</scope>\r\n        </dependency>\r\n    </dependencies>\r\n\r\n    <build>\r\n        <resources>\r\n            <!-- Include native DLL in JAR (loaded from build folder) -->\r\n            <resource>\r\n                <directory>build</directory>\r\n                <includes>\r\n                    <include>*.dll</include>\r\n                </includes>\r\n            </resource>\r\n            <!-- Standard resources -->\r\n            <resource>\r\n                <directory>src/main/resources</directory>\r\n            </resource>\r\n        </resources>\r\n\r\n        <plugins>\r\n            <!-- Maven Compiler Plugin -->\r\n            <plugin>\r\n                <groupId>org.apache.maven.plugins</groupId>\r\n                <artifactId>maven-compiler-plugin</artifactId>\r\n                <version>3.11.0</version>\r\n                <configuration>\r\n                    <source>17</source>\r\n                    <target>17</target>\r\n                </configuration>\r\n            </plugin>\r\n\r\n            <!-- Maven Surefire Plugin for Tests -->\r\n            <plugin>\r\n                <groupId>org.apache.maven.plugins</groupId>\r\n                <artifactId>maven-surefire-plugin</artifactId>\r\n                <version>3.1.2</version>\r\n                <configuration>\r\n                    <includes>\r\n                        <include>**/*Test.java</include>\r\n                    </includes>\r\n                </configuration>\r\n            </plugin>\r\n\r\n            <!-- Maven JAR Plugin -->\r\n            <plugin>\r\n                <groupId>org.apache.maven.plugins</groupId>\r\n                <artifactId>maven-jar-plugin</artifactId>\r\n                <version>3.3.0</version>\r\n                <configuration>\r\n                    <archive>\r\n                        <manifest>\r\n                            <addClasspath>true</addClasspath>\r\n                        </manifest>\r\n                    </archive>\r\n                </configuration>\r\n            </plugin>\r\n\r\n            <!-- Maven Source Plugin -->\r\n            <plugin>\r\n                <groupId>org.apache.maven.plugins</groupId>\r\n                <artifactId>maven-source-plugin</artifactId>\r\n                <version>3.3.0</version>\r\n                <executions>\r\n                    <execution>\r\n                        <id>attach-sources</id>\r\n                        <goals>\r\n                            <goal>jar</goal>\r\n                        </goals>\r\n                    </execution>\r\n                </executions>\r\n            </plugin>\r\n        </plugins>\r\n    </build>\r\n</project>\r\n
